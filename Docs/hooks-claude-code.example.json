    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/codex-traffic-light-mxp/.build/release/codex-light-hook-mxp UserPromptSubmit",
            "timeout": 5
          }
        ]
      }
